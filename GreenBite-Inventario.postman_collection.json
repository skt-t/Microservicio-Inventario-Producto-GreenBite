            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Tomate perita\",\n  \"descripcion\": \"Tomate fresco de temporada\",\n  \"precio\": 1200.00,\n  \"stock\": 100,\n  \"categoria\": \"Verduras\",\n  \"imagenUrl\": \"https://ejemplo.com/tomate.png\"\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/productos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "productos"]
        }
      }
    },
    {
      "name": "2. Listar Catálogo Completo",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/productos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "productos"]
        }
      }
    },
    {
      "name": "3. Buscar Producto",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/productos/buscar?nombre=tomate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
